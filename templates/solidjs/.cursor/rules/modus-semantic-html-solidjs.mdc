```

### ✅ **Navigation with Divs**

```tsx
// ✅ CORRECT: Navigation using divs
function Navigation() {
  const navItems = [
    { label: "Home", path: "/" },
    { label: "About", path: "/about" },
    { label: "Contact", path: "/contact" },
  ];

  return (
    <div class="bg-background border-b border-border">
      <div class="container mx-auto px-4 py-4">
        <div class="flex space-x-6">
          <For each={navItems}>
            {(item) => (
              <a
                href={item.path}
                class="text-foreground hover:text-primary transition-colors"
              >
                {item.label}
              </a>
            )}
          </For>
        </div>
      </div>
    </div>
  );
}
```

### ✅ **Form with Divs**

```tsx
// ✅ CORRECT: Form using divs
function ContactForm() {
  const [formData, setFormData] = createSignal({
    name: "",
    email: "",
    message: "",
  });

  const handleSubmit = (e: Event) => {
    e.preventDefault();
    console.log("Form data:", formData());
  };

  return (
    <div class="max-w-md mx-auto p-6 bg-card border border-border rounded-lg">
      <div class="text-2xl font-bold mb-6 text-card-foreground">
        Contact Us
      </div>

      <div onSubmit={handleSubmit}>
        <div class="mb-4">
          <div class="block text-sm font-medium text-card-foreground mb-2">
            Name
          </div>
          <input
            type="text"
            value={formData().name}
            onInput={(e) =>
              setFormData((prev) => ({ ...prev, name: e.target.value }))
            }
            class="w-full px-3 py-2 border border-input rounded bg-input text-foreground"
            required
          />
        </div>

        <div class="mb-4">
          <div class="block text-sm font-medium text-card-foreground mb-2">
            Email
          </div>
          <input
            type="email"
            value={formData().email}
            onInput={(e) =>
              setFormData((prev) => ({ ...prev, email: e.target.value }))
            }
            class="w-full px-3 py-2 border border-input rounded bg-input text-foreground"
            required
          />
        </div>

        <div class="mb-6">
          <div class="block text-sm font-medium text-card-foreground mb-2">
            Message
          </div>
          <textarea
            value={formData().message}
            onInput={(e) =>
              setFormData((prev) => ({ ...prev, message: e.target.value }))
            }
            class="w-full px-3 py-2 border border-input rounded bg-input text-foreground h-32"
            required
          />
        </div>

        <button
          type="submit"
          class="w-full bg-primary text-primary-foreground py-2 px-4 rounded hover:bg-primary/90"
        >
          Send Message
        </button>
      </div>
    </div>
  );
}
```

