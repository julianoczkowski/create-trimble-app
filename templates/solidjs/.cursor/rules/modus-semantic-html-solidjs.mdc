## 🎯 **Component Patterns**

### ✅ **Page Layout with Divs**

```tsx
// ✅ CORRECT: Page layout using divs
function PageLayout({ children }: { children: JSX.Element }) {
  return (
    <div class="min-h-screen flex flex-col">
      <div class="bg-background border-b border-border">
        <div class="container mx-auto px-4 py-4">
          <div class="text-2xl font-bold text-foreground">App Title</div>
        </div>
      </div>

      <div class="flex-1">{children}</div>

      <div class="bg-muted border-t border-border">
        <div class="container mx-auto px-4 py-4">
          <div class="text-sm text-muted-foreground">Footer content</div>
        </div>
      </div>
    </div>
  );
}
```

### ✅ **Card Component with Divs**

```tsx
// ✅ CORRECT: Card component using divs
function Card({ title, content, children }: CardProps) {
  return (
    <div class="bg-card text-card-foreground border border-border rounded-lg p-6">
      <div class="text-xl font-semibold mb-4">{title}</div>
      <div class="text-base mb-4">{content}</div>
      {children}
    </div>
  );
}

// Usage
<Card title="Card Title" content="Card content">
  <div class="text-sm text-muted-foreground">Additional content</div>
