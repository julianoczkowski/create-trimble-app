### ✅ **Event Handling Patterns**

```tsx
// ✅ CORRECT: Event handling with refs
import { onMount, onCleanup } from "solid-js";
import {
  ModusWcButton,
  ModusWcTextInput,
} from "@trimble-oss/moduswebcomponents-solidjs";

function EventHandlingComponent() {
  let buttonRef: ModusWcButton | undefined;
  let inputRef: ModusWcTextInput | undefined;

  onMount(() => {
    if (!buttonRef || !inputRef) return;

    const handleButtonClick = (event: CustomEvent) => {
      console.log("Button clicked:", event.detail);
    };

    const handleInputChange = (event: CustomEvent) => {
      console.log("Input changed:", event.detail);
    };

    buttonRef.addEventListener("buttonClick", handleButtonClick);
    inputRef.addEventListener("inputChange", handleInputChange);

    onCleanup(() => {
      buttonRef?.removeEventListener("buttonClick", handleButtonClick);
      inputRef?.removeEventListener("inputChange", handleInputChange);
    });
  });

  return (
    <div class="space-y-4">
      <ModusWcButton ref={buttonRef}>Click me</ModusWcButton>

      <ModusWcTextInput
        ref={inputRef}
        placeholder="Type something"
        class="w-full"
      />
    </div>
  );
}
```

### ✅ **State Management Integration**

```tsx
// ✅ CORRECT: State management with Modus components
import { createSignal } from "solid-js";
import {
  ModusWcModal,
  ModusWcButton,
} from "@trimble-oss/moduswebcomponents-solidjs";

function StatefulComponent() {
  const [isModalOpen, setIsModalOpen] = createSignal(false);
  let modalRef: ModusWcModal | undefined;

  const openModal = () => {
    if (modalRef) {
      const dialog = modalRef.querySelector(
        "dialog"
      ) as HTMLDialogElement;
      if (dialog) {
        dialog.showModal();
        setIsModalOpen(true);
      }
    }
  };

  const closeModal = () => {
    if (modalRef) {
      const dialog = modalRef.querySelector(
        "dialog"
      ) as HTMLDialogElement;
      if (dialog) {
        dialog.close();
        setIsModalOpen(false);
      }
    }
  };

  return (
    <div>
      <ModusWcButton onClick={openModal}>Open Modal</ModusWcButton>

      <ModusWcModal ref={modalRef}>
        <div slot="header">Modal Title</div>
        <div slot="body">Modal content</div>
        <div slot="footer">
          <ModusWcButton onClick={closeModal}>Close</ModusWcButton>
        </div>
      </ModusWcModal>
    </div>
  );
}
```

