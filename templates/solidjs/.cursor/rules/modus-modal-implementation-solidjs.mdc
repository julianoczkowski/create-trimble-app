## 🎉 **Successfully Implemented Pattern**

### **Working Implementation Example:**

```tsx
// ✅ SUCCESSFUL: Our working implementation
import { ModusWcModal } from "@trimble-oss/moduswebcomponents-solidjs";
import { useRef } from "solid-js";

export interface ModusModalRef {
  openModal: () => void;
  closeModal: () => void;
}

const ModusModal = callback ref<ModusModalRef, ModusModalProps>(
  (
    {
      modalId,
      ariaLabel,
      backdrop = "default",
      position = "center",
      fullscreen = false,
      showFullscreenToggle = false,
      showClose = true,
      customClass,
      header,
      children,
      footer,
      onClose,
      className,
    },
    ref
  ) => {
    const modalRef = useRef<HTMLModusWcModalElement>(null);

    const openModal = () => {
      if (modalRef.current) {
        const dialog = modalRef.current.querySelector(
          "dialog"
        ) as HTMLDialogElement;
        if (dialog) {
          dialog.showModal();
        }
      }
    };

    const closeModal = () => {
      if (modalRef.current) {
        const dialog = modalRef.current.querySelector(
          "dialog"
        ) as HTMLDialogElement;
        if (dialog) {
          dialog.close();
        }
      }
    };

    expose via callback ref(ref, () => ({
      openModal,
      closeModal,
    }));

    return (
      <ModusWcModal
        ref={modalRef}
        modal-id={modalId}
        aria-label={ariaLabel}
        backdrop={backdrop}
        position={position}
        fullscreen={fullscreen}
        show-fullscreen-toggle={showFullscreenToggle}
        show-close={showClose}
        custom-class={customClass || className}
      >
        {header && <div slot="header">{header}</div>}
        <div slot="content">{children}</div>
        {footer && <div slot="footer">{footer}</div>}
      </ModusWcModal>
    );
  }
);

// Usage in parent component
function ParentComponent() {
  const modalRef = useRef<ModusModalRef>(null);

  return (
    <div>
      <button onClick={() => modalRef.current?.openModal()}>Open Modal</button>
      <ModusModal
        ref={modalRef}
        modalId="my-modal"
        onClose={() => console.log("Modal closed")}
        header={<div>Modal Title</div>}
        footer={<div>Modal Actions</div>}
      >
        <div>Modal Content</div>
      </ModusModal>
    </div>
  );
}
```

### **Benefits of This Pattern:**

- ✅ **Follows Official Documentation**: Aligns with Modus documentation exactly
- ✅ **No React State Control**: Uses direct method calls as documented
- ✅ **Type Safety**: Full TypeScript support with proper interfaces
- ✅ **Reusable**: Can be used across the application consistently
- ✅ **Performance**: No unnecessary re-renders from state changes
- ✅ **Maintainable**: Clear separation of concerns

---

**Remember: ModusWcModal methods are on the inner dialog element, not the component itself. Always use `querySelector('dialog')` to access the native dialog element and call methods on it. This ensures proper modal functionality in SolidJS applications and aligns with the official Modus documentation.**
