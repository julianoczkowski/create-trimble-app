// ✅ CORRECT: Reusable modal helper
function createModal() {
  let modalRef: ModusWcModal | undefined;

  const setRef = (el: ModusWcModal) => {
    modalRef = el;
  };

  const openModal = () => {
    if (modalRef) {
      const dialog = modalRef.querySelector(
        "dialog"
      ) as HTMLDialogElement;
      if (dialog) {
        dialog.showModal();
      }
    }
  };

  const closeModal = () => {
    if (modalRef) {
      const dialog = modalRef.querySelector(
        "dialog"
      ) as HTMLDialogElement;
      if (dialog) {
        dialog.close();
      }
    }
  };

  return {
    setRef,
    openModal,
    closeModal,
  };
}

// ✅ CORRECT: Use the helper
function ModalComponent() {
  const { setRef, openModal, closeModal } = createModal();

  return (
    <div>
      <button onClick={openModal}>Open Modal</button>
      <ModusWcModal ref={setRef}>
        <div slot="header">Modal Header</div>
        <div slot="body">Modal Body</div>
