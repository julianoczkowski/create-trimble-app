## 🎉 **Successfully Implemented Pattern**

### **Working Implementation Example:**

```tsx
// ✅ SUCCESSFUL: Our working implementation
import { ModusWcModal } from "@trimble-oss/moduswebcomponents";
import { onMount, onCleanup } from "solid-js";

export interface ModusModalHandle {
  openModal: () => void;
  closeModal: () => void;
}

interface ModusModalProps {
  modalId?: string;
  ariaLabel?: string;
  backdrop?: string;
  position?: string;
  fullscreen?: boolean;
  showFullscreenToggle?: boolean;
  showClose?: boolean;
  customClass?: string;
  header?: JSX.Element;
  children?: JSX.Element;
  footer?: JSX.Element;
  onClose?: () => void;
  ref?: (handle: ModusModalHandle) => void;
}

function ModusModal(props: ModusModalProps) {
  let modalRef: HTMLModusWcModalElement | undefined;

  const openModal = () => {
    if (modalRef) {
      const dialog = modalRef.querySelector(
        "dialog"
      ) as HTMLDialogElement;
      if (dialog) {
        dialog.showModal();
      }
    }
  };

  const closeModal = () => {
    if (modalRef) {
      const dialog = modalRef.querySelector(
        "dialog"
      ) as HTMLDialogElement;
      if (dialog) {
        dialog.close();
      }
    }
  };

  // Expose methods via ref callback
  props.ref?.({ openModal, closeModal });

  return (
    <ModusWcModal
      ref={(el) => (modalRef = el)}
      modal-id={props.modalId}
      aria-label={props.ariaLabel}
      backdrop={props.backdrop ?? "default"}
      position={props.position ?? "center"}
      fullscreen={props.fullscreen ?? false}
      show-fullscreen-toggle={props.showFullscreenToggle ?? false}
      show-close={props.showClose ?? true}
      custom-class={props.customClass}
    >
      {props.header && <div slot="header">{props.header}</div>}
      <div slot="content">{props.children}</div>
      {props.footer && <div slot="footer">{props.footer}</div>}
    </ModusWcModal>
  );
}

// Usage in parent component
function ParentComponent() {
  let modalHandle: ModusModalHandle | undefined;

  return (
    <div>
      <button onClick={() => modalHandle?.openModal()}>Open Modal</button>
      <ModusModal
        ref={(handle) => (modalHandle = handle)}
        modalId="my-modal"
        onClose={() => console.log("Modal closed")}
        header={<div>Modal Title</div>}
        footer={<div>Modal Actions</div>}
      >
        <div>Modal Content</div>
      </ModusModal>
    </div>
  );
}
```

### **Benefits of This Pattern:**

- ✅ **Follows Official Documentation**: Aligns with Modus documentation exactly
- ✅ **No SolidJS State Control**: Uses direct method calls as documented
- ✅ **Type Safety**: Full TypeScript support with proper interfaces
- ✅ **Reusable**: Can be used across the application consistently
- ✅ **Performance**: No unnecessary re-renders from state changes
- ✅ **Maintainable**: Clear separation of concerns

---

**Remember: ModusWcModal methods are on the inner dialog element, not the component itself. Always use `querySelector('dialog')` to access the native dialog element and call methods on it. This ensures proper modal functionality in SolidJS applications and aligns with the official Modus documentation.**
