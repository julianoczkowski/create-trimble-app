### ✅ **Modal with SolidJS State Tracking**

```tsx
// ✅ CORRECT: Track modal state without controlling it
function ModalComponent() {
  let modalRef: ModusWcModal | undefined;
  const [isModalOpen, setIsModalOpen] = createSignal(false);

  const openModal = () => {
    if (modalRef) {
      const dialog = modalRef.querySelector(
        "dialog"
      ) as HTMLDialogElement;
      if (dialog) {
        dialog.showModal();
        setIsModalOpen(true); // ✅ CORRECT: Track state for UI updates
      }
    }
  };

  const closeModal = () => {
    if (modalRef) {
      const dialog = modalRef.querySelector(
        "dialog"
      ) as HTMLDialogElement;
      if (dialog) {
        dialog.close();
        setIsModalOpen(false); // ✅ CORRECT: Track state for UI updates
      }
    }
  };

  // ✅ CORRECT: Listen to modal events
  const handleModalClose = () => {
    setIsModalOpen(false);
  };

  return (
    <div>
      <button onClick={openModal}>Open Modal</button>
      {isModalOpen() && <div>Modal is open</div>}

      <ModusWcModal ref={(el) => (modalRef = el)} onClose={handleModalClose}>
        <div slot="header">Modal Header</div>
        <div slot="body">Modal Body</div>
        <div slot="footer">
          <button onClick={closeModal}>Close</button>
        </div>
      </ModusWcModal>
    </div>
  );
}
```

