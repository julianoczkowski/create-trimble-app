## 🎯 **Modus Web Components Integration**

### ✅ **Event Handling Patterns**

```tsx
// ✅ CORRECT: Event handling with refs
function ModusComponent() {
  let componentRef: ModusWcButton | undefined;

  onMount(() => {
    if (!componentRef) return;

    const handleClick = (event: CustomEvent) => {
      console.log("Button clicked:", event.detail);
    };

    componentRef.addEventListener("click", handleClick);

    onCleanup(() => {
      componentRef?.removeEventListener("click", handleClick);
    });
  });

  return <ModusWcButton ref={componentRef}>Click me</ModusWcButton>;
}
```

### ✅ **State Management Patterns**

```tsx
// ✅ CORRECT: State management with Modus components
function StatefulComponent() {
  const [isOpen, setIsOpen] = createSignal(false);
  let modalRef: ModusWcModal | undefined;

  const openModal = () => {
    if (modalRef) {
      const dialog = modalRef.querySelector(
        "dialog"
      ) as HTMLDialogElement;
      if (dialog) {
        dialog.showModal();
        setIsOpen(true);
      }
    }
  };

  const closeModal = () => {
    if (modalRef) {
      const dialog = modalRef.querySelector(
        "dialog"
      ) as HTMLDialogElement;
      if (dialog) {
        dialog.close();
        setIsOpen(false);
      }
    }
  };

  return (
    <div>
      <button onClick={openModal}>Open Modal</button>
      <ModusWcModal ref={modalRef}>
        <div slot="header">Modal Title</div>
        <div slot="body">Modal content</div>
        <div slot="footer">
          <button onClick={closeModal}>Close</button>
        </div>
      </ModusWcModal>
    </div>
  );
}
```

