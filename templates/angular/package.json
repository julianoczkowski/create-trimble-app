{
  "name": "modus-angular-app",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "type-check": "node scripts/check-typescript.js",
    "lint:colors": "node scripts/check-modus-colors.js",
    "lint:styles": "node scripts/check-inline-styles.js",
    "lint:borders": "node scripts/check-border-violations.js",
    "lint:opacity": "node scripts/check-opacity-utilities.js",
    "lint:icons": "node scripts/check-modus-icons.js",
    "lint:icon-names": "node scripts/check-icon-names.js",
    "lint:all": "node scripts/run-all-checks.js",
    "prepare": "husky || true"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^21.2.5",
    "@angular/compiler": "^21.2.5",
    "@angular/core": "^21.2.5",
    "@angular/forms": "^21.2.5",
    "@angular/platform-browser": "^21.2.5",
    "@angular/router": "^21.2.5",
    "@tailwindcss/postcss": "^4.2.2",
    "@trimble-oss/modus-icons": "^1.21.0",
    "@trimble-oss/moduswebcomponents": "^1.1.1",
    "@trimble-oss/moduswebcomponents-angular": "^1.0.6-ng19",
    "postcss": "^8.5.8",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.1.16",
    "tslib": "^2.3.0",
    "zone.js": "~0.16.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.5",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "typescript": "~6.0.2",
    "vitest": "^4.1.1"
  }
}
